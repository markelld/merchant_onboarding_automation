<h1>Automation Run</h1>

<p><strong>Status:</strong> <%= @run.status %></p>
<p><strong>Merchant:</strong> <%= @run.merchant_intake.merchant_name %></p>

<% if @run.advertiser %>
  <p><strong>Advertiser ID:</strong> <%= @run.advertiser.advertiser_external_id %></p>
<% end %>

<% if @run.offer %>
  <p><strong>Offer ID:</strong> <%= @run.offer.offer_external_id %></p>
<% end %>

<% if @run.integration_task %>
  <p><strong>Asana Task GID:</strong> <%= @run.integration_task.asana_task_gid %></p>
<% end %>

<% if @run.error_message.present? %>
  <p><strong>Error:</strong> <%= @run.error_message %></p>
<% end %>