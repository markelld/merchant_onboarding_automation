<div class="fixed inset-0 flex justify-center items-center bg-blue-200">
  <div class="max-w-xl w-full bg-white shadow rounded-xl p-8">
    <h1 class="text-2xl font-bold mb-6">Advertiser Created</h1>

    <div class="mb-4">
      <strong class="block text-sm font-medium text-gray-700 mb-1">Advertiser ID:</strong>
      <span data-testid="advertiser-id" class="text-gray-900"><%= @advertiser.advertiser_external_id %></span>
    </div>

    <div class="mb-6">
      <strong class="block text-sm font-medium text-gray-700 mb-1">Merchant:</strong>
      <span class="text-gray-900"><%= @advertiser.merchant_name %></span>
    </div>

    <%= link_to "Create Offer",
        "/portal/offers/new?advertiser_id=#{@advertiser.id}",
        data: { testid: "go-to-offer" },
        class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 inline-block" %>
  </div>
</div>