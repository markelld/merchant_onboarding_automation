<div class="fixed inset-0 flex justify-center items-center bg-blue-200">
  <div class="max-w-xl w-full bg-white shadow rounded-xl p-8">
    <h1 class="text-2xl font-bold mb-6">Portal Login</h1>

    <%= form_with url: "/portal/login", method: :post do %>

      <div class="mb-4">
        <%= label_tag :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= email_field_tag :email, nil, data: { testid: "portal-email" }, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div class="mb-4">
        <%= label_tag :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= password_field_tag :password, nil, data: { testid: "portal-password" }, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500" %>
      </div>

      <div>
        <%= submit_tag "Login", data: { testid: "portal-login-submit" }, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
      </div>

    <% end %>
  </div>
</div>