<div class="fixed inset-0 flex justify-center items-center bg-blue-200">
  <div class="max-w-xl w-full bg-white shadow rounded-xl p-8">
    <h1 class="text-2xl font-bold mb-6">Merchant Intake</h1>

    <%= form_with model: @merchant_intake, local: true do |f| %>
      <div class="mb-4">
        <%= f.label :google_doc_url, "Google Doc URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :google_doc_url,
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500" %>
      </div>

      <%= f.submit "Create Intake",
        class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
    <% end %>
  </div>
</div>